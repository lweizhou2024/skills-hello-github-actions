%% File names
stlFile = 'model.stl';
txtFile = 'points_vectors.txt';

%% Read STL file
TR = stlread(stlFile);

% Depending on the MATLAB version, stlread may return either a
% triangulation object or a structure.
if isa(TR, 'triangulation')
    faces    = TR.ConnectivityList;
    vertices = TR.Points;
elseif isstruct(TR)
    if isfield(TR, 'ConnectivityList')
        faces = TR.ConnectivityList;
    elseif isfield(TR, 'faces')
        faces = TR.faces;
    else
        error('Could not find STL face connectivity.');
    end

    if isfield(TR, 'Points')
        vertices = TR.Points;
    elseif isfield(TR, 'vertices')
        vertices = TR.vertices;
    else
        error('Could not find STL vertices.');
    end
else
    error('Unrecognized output from stlread.');
end

%% Read point and vector data
% Expected format for each line:
% x  y  z  ux  uy  uz
data = readmatrix(txtFile);

% Remove empty or invalid lines
data = data(all(isfinite(data(:,1:6)), 2), :);

if size(data, 2) < 6
    error('The text file must contain at least six numeric columns.');
end

points  = data(:, 1:3);
vectors = data(:, 4:6);

%% Normalize the vectors
% This ensures that vectors are unit vectors even if the input contains
% small numerical errors.
vectorLength = vecnorm(vectors, 2, 2);

validVector = vectorLength > eps;
vectors(validVector, :) = ...
    vectors(validVector, :) ./ vectorLength(validVector);

%% Choose vector display length
% Use approximately 5% of the STL model size.
modelRange = max(vertices, [], 1) - min(vertices, [], 1);
modelSize  = norm(modelRange);

vectorScale = 0.05 * modelSize;

%% Plot STL
figure;
hold on;

patch( ...
    'Faces', faces, ...
    'Vertices', vertices, ...
    'FaceColor', [0.75 0.80 0.85], ...
    'EdgeColor', 'none', ...
    'FaceAlpha', 0.7);

%% Plot points
scatter3( ...
    points(:,1), points(:,2), points(:,3), ...
    35, 'filled');

%% Plot vectors
quiver3( ...
    points(:,1), points(:,2), points(:,3), ...
    vectors(:,1), vectors(:,2), vectors(:,3), ...
    vectorScale, ...
    'LineWidth', 1.5, ...
    'MaxHeadSize', 0.5);

%% Plot settings
axis equal;
grid on;
view(3);

xlabel('X');
ylabel('Y');
zlabel('Z');

title('STL Model with Points and Unit Vectors');

camlight headlight;
lighting gouraud;

hold off;
