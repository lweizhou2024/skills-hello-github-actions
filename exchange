%% filter_tet_elements.m
% Reads an Abaqus .inp deck, extracts *NODE and *ELEMENT (C3D10M) blocks,
% computes each element's centroid radius in the YZ plane (r = sqrt(y^2+z^2)),
% and removes elements whose centroid radius < r0 AND centroid x is within [x1, x2].
%
% Nodes are left untouched (all kept). Remaining elements keep their
% original element IDs (only matching rows are deleted from the deck).

clear; clc;

%% ---- USER INPUTS ----
inputFile  = 'model.inp';      % path to source Abaqus input deck
outputFile = 'model_filtered.inp';

r0 = 5.0;     % radius threshold
x1 = 0.0;     % lower x bound
x2 = 10.0;    % upper x bound

elemTypeTag = 'C3D10M';  % element type to filter (case-insensitive match in *ELEMENT line)

%% ---- READ FILE ----
fid = fopen(inputFile, 'r');
if fid == -1
    error('Could not open file: %s', inputFile);
end
rawLines = {};
tline = fgetl(fid);
while ischar(tline)
    rawLines{end+1,1} = tline; %#ok<AGROW>
    tline = fgetl(fid);
end
fclose(fid);
nLines = numel(rawLines);

%% ---- LOCATE *NODE BLOCK(S) ----
nodeIDs    = [];
nodeCoords = [];   % [x y z]

isKeyword = @(s) ~isempty(s) && s(1) == '*';

i = 1;
while i <= nLines
    line = strtrim(rawLines{i});
    if ~isempty(line) && line(1) == '*' && ~isempty(regexpi(line, '^\*NODE\b', 'once'))
        % consume following data lines until next keyword line
        j = i + 1;
        while j <= nLines
            dl = strtrim(rawLines{j});
            if isempty(dl)
                j = j + 1;
                continue;
            end
            if isKeyword(dl)
                break;
            end
            parts = strsplit(dl, ',');
            parts = strtrim(parts);
            id = str2double(parts{1});
            x  = str2double(parts{2});
            y  = str2double(parts{3});
            z  = str2double(parts{4});
            nodeIDs(end+1,1)      = id; %#ok<AGROW>
            nodeCoords(end+1,:)   = [x y z]; %#ok<AGROW>
            j = j + 1;
        end
        i = j;
    else
        i = i + 1;
    end
end

% Map node ID -> row index for fast lookup
maxNodeID = max(nodeIDs);
nodeMap = zeros(maxNodeID, 1);
nodeMap(nodeIDs) = 1:numel(nodeIDs);

%% ---- LOCATE *ELEMENT BLOCK(S) MATCHING elemTypeTag ----
% Store: element ID, connectivity (variable length, but C3D10M = 10 nodes),
% and the line range [startLine endLine] in rawLines so we can delete later.

elemIDs   = [];
elemConn  = {};   % cell array of node-id vectors
elemLineRange = []; % [startLine endLine] per element (continuation lines included)

i = 1;
while i <= nLines
    line = strtrim(rawLines{i});
    if ~isempty(line) && line(1) == '*' && ~isempty(regexpi(line, '^\*ELEMENT\b', 'once'))
        isTarget = ~isempty(regexpi(line, elemTypeTag, 'once'));
        j = i + 1;
        while j <= nLines
            dl = strtrim(rawLines{j});
            if isempty(dl)
                j = j + 1;
                continue;
            end
            if isKeyword(dl)
                break;
            end
            % Abaqus allows continuation lines ending with a comma.
            startLn = j;
            fullStr = dl;
            while ~isempty(fullStr) && fullStr(end) == ',' && (j+1) <= nLines
                j = j + 1;
                fullStr = [fullStr, strtrim(rawLines{j})]; %#ok<AGROW>
            end
            endLn = j;

            parts = strsplit(fullStr, ',');
            parts = strtrim(parts);
            parts = parts(~cellfun(@isempty, parts));
            vals  = str2double(parts);

            if isTarget
                elemIDs(end+1,1)        = vals(1); %#ok<AGROW>
                elemConn{end+1,1}       = vals(2:end); %#ok<AGROW>
                elemLineRange(end+1,:)  = [startLn endLn]; %#ok<AGROW>
            end
            j = j + 1;
        end
        i = j;
    else
        i = i + 1;
    end
end

fprintf('Parsed %d nodes and %d %s elements.\n', numel(nodeIDs), numel(elemIDs), elemTypeTag);

%% ---- COMPUTE CENTROID & RADIUS (using corner nodes 1-4 of C3D10M) ----
nElem = numel(elemIDs);
centroid = zeros(nElem, 3);
for k = 1:nElem
    conn = elemConn{k};
    cornerNodes = conn(1:4);          % corner nodes of the 10-node tet
    rows = nodeMap(cornerNodes);
    centroid(k,:) = mean(nodeCoords(rows, :), 1);
end

x_c = centroid(:,1);
r_c = sqrt(centroid(:,2).^2 + centroid(:,3).^2);

%% ---- APPLY REMOVAL CRITERION ----
removeMask = (r_c < r0) & (x_c >= x1) & (x_c <= x2);

fprintf('Removing %d of %d elements (r < %.4g and x in [%.4g, %.4g]).\n', ...
    sum(removeMask), nElem, r0, x1, x2);

linesToDelete = false(nLines, 1);
removedRanges = elemLineRange(removeMask, :);
for k = 1:size(removedRanges,1)
    linesToDelete(removedRanges(k,1):removedRanges(k,2)) = true;
end

%% ---- WRITE OUTPUT FILE (nodes untouched, flagged element lines removed) ----
keepLines = rawLines(~linesToDelete);

fidOut = fopen(outputFile, 'w');
if fidOut == -1
    error('Could not open output file: %s', outputFile);
end
for k = 1:numel(keepLines)
    fprintf(fidOut, '%s\n', keepLines{k});
end
fclose(fidOut);

fprintf('Wrote filtered deck to: %s\n', outputFile);
