%% filter_tet_elements.m
% Reads an Abaqus .inp deck with exactly ONE *Node block and ONE *Element
% block. Computes each element's centroid radius in the YZ plane
% (r = sqrt(y^2+z^2)) using its 4 corner nodes, and removes elements whose
% centroid radius < r0 AND centroid x is within [x1, x2].
%
% Nodes are left untouched (all kept). Surviving elements keep their
% original IDs. An *ELSET named ABRBOT is appended, listing the element
% IDs in the range [elsetLo, elsetHi] that survived the filtering.

clear; clc;

%% ---- USER INPUTS ----
inputFile  = 'model.inp';
outputFile = 'model_filtered.inp';

r0 = 5.0;     % radius threshold
x1 = 0.0;     % lower x bound
x2 = 10.0;    % upper x bound

elsetLo = 661506;   % lower bound of element ID range for ABRBOT elset
elsetHi = 886647;   % upper bound of element ID range for ABRBOT elset

%% ---- READ FILE ----
fid = fopen(inputFile, 'r');
if fid == -1
    error('Could not open file: %s', inputFile);
end
rawLines = {};
tline = fgetl(fid);
while ischar(tline)
    rawLines{end+1,1} = tline; %#ok<AGROW>
    tline = fgetl(fid);
end
fclose(fid);
nLines = numel(rawLines);

isKeyword = @(s) ~isempty(s) && s(1) == '*';

%% ---- FIND *Node BLOCK (case-insensitive, single block) ----
nodeStart = find(~cellfun(@isempty, regexpi(rawLines, '^\*Node\b', 'once')), 1);
if isempty(nodeStart)
    error('Could not find a *Node keyword line.');
end

j = nodeStart + 1;
nodeIDs    = [];
nodeCoords = [];
while j <= nLines
    dl = strtrim(rawLines{j});
    if isempty(dl)
        j = j + 1;
        continue;
    end
    if isKeyword(dl)
        break;
    end
    parts = strsplit(dl, ',');
    parts = strtrim(parts);
    id = str2double(parts{1});
    x  = str2double(parts{2});
    y  = str2double(parts{3});
    z  = str2double(parts{4});
    nodeIDs(end+1,1)    = id; %#ok<AGROW>
    nodeCoords(end+1,:) = [x y z]; %#ok<AGROW>
    j = j + 1;
end
nodeBlockEnd = j - 1;

maxNodeID = max(nodeIDs);
nodeMap = zeros(maxNodeID, 1);
nodeMap(nodeIDs) = 1:numel(nodeIDs);

fprintf('Parsed %d nodes (lines %d-%d).\n', numel(nodeIDs), nodeStart, nodeBlockEnd);

%% ---- FIND *Element BLOCK (case-insensitive, single block) ----
elemStart = find(~cellfun(@isempty, regexpi(rawLines, '^\*Element\b', 'once')), 1);
if isempty(elemStart)
    error('Could not find an *Element keyword line.');
end

j = elemStart + 1;
elemIDs       = [];
elemConn      = {};
elemLineRange = [];   % [startLine endLine] per element, for deletion
while j <= nLines
    dl = strtrim(rawLines{j});
    if isempty(dl)
        j = j + 1;
        continue;
    end
    if isKeyword(dl)
        break;
    end
    startLn = j;
    fullStr = dl;
    while ~isempty(fullStr) && fullStr(end) == ',' && (j+1) <= nLines
        j = j + 1;
        fullStr = [fullStr, strtrim(rawLines{j})]; %#ok<AGROW>
    end
    endLn = j;

    parts = strsplit(fullStr, ',');
    parts = strtrim(parts);
    parts = parts(~cellfun(@isempty, parts));
    vals  = str2double(parts);

    elemIDs(end+1,1)       = vals(1); %#ok<AGROW>
    elemConn{end+1,1}      = vals(2:end); %#ok<AGROW>
    elemLineRange(end+1,:) = [startLn endLn]; %#ok<AGROW>

    j = j + 1;
end

fprintf('Parsed %d elements (lines %d-%d).\n', numel(elemIDs), elemStart, j-1);

%% ---- COMPUTE CENTROID & RADIUS (corner nodes 1-4 of 10-node tet) ----
nElem = numel(elemIDs);
centroid = zeros(nElem, 3);
for k = 1:nElem
    conn = elemConn{k};
    cornerNodes = conn(1:4);
    rows = nodeMap(cornerNodes);
    centroid(k,:) = mean(nodeCoords(rows, :), 1);
end

x_c = centroid(:,1);
r_c = sqrt(centroid(:,2).^2 + centroid(:,3).^2);

%% ---- APPLY REMOVAL CRITERION ----
removeMask = (r_c < r0) & (x_c >= x1) & (x_c <= x2);

fprintf('Removing %d of %d elements (r < %.4g and x in [%.4g, %.4g]).\n', ...
    sum(removeMask), nElem, r0, x1, x2);

linesToDelete = false(nLines, 1);
removedRanges = elemLineRange(removeMask, :);
for k = 1:size(removedRanges,1)
    linesToDelete(removedRanges(k,1):removedRanges(k,2)) = true;
end

%% ---- BUILD ABRBOT ELSET (surviving elements within [elsetLo, elsetHi]) ----
keptMask    = ~removeMask;
inRangeMask = (elemIDs >= elsetLo) & (elemIDs <= elsetHi);
abrbotIDs   = elemIDs(keptMask & inRangeMask);
abrbotIDs   = sort(abrbotIDs);

fprintf('ABRBOT elset: %d elements remain in range [%d, %d].\n', ...
    numel(abrbotIDs), elsetLo, elsetHi);

%% ---- WRITE OUTPUT FILE ----
keepLines = rawLines(~linesToDelete);

fidOut = fopen(outputFile, 'w');
if fidOut == -1
    error('Could not open output file: %s', outputFile);
end
for k = 1:numel(keepLines)
    fprintf(fidOut, '%s\n', keepLines{k});
end

% Append the ABRBOT elset definition, 8 IDs per line
fprintf(fidOut, '*ELSET, ELSET=ABRBOT\n');
nPerLine = 8;
for k = 1:nPerLine:numel(abrbotIDs)
    lineIDs = abrbotIDs(k:min(k+nPerLine-1, numel(abrbotIDs)));
    fprintf(fidOut, '%s\n', strjoin(cellstr(num2str(lineIDs(:), '%d')), ', '));
end

fclose(fidOut);

fprintf('Wrote filtered deck with ABRBOT elset to: %s\n', outputFile);
