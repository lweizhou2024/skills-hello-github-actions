%% filter_tet_elements.m
% Single *Node block, single *Element block. Computes each element's
% centroid radius in the YZ plane (r = sqrt(y^2+z^2)) from its 4 corner
% nodes, and removes elements whose centroid radius < r0 AND centroid x
% is within [x1, x2]. Nodes are untouched. Surviving elements keep their
% original IDs. An *ELSET named ABRBOT lists surviving element IDs within
% [elsetLo, elsetHi].
%
% ASSUMPTION: each element's connectivity (id + 10 node IDs) fits on a
% single line (true for standard C3D10/C3D10M decks, which have 11
% fields per element -- well under Abaqus's 16-value line limit). If
% your deck wraps elements across multiple lines, let me know and this
% will need a small change.

clear; clc;

%% ---- USER INPUTS ----
inputFile  = 'model.inp';
outputFile = 'model_filtered.inp';

r0 = 5.0;
x1 = 0.0;
x2 = 10.0;

elsetLo = 661506;
elsetHi = 886647;

%% ---- READ ALL LINES (text I/O, not the slow part) ----
fid = fopen(inputFile, 'r');
if fid == -1
    error('Could not open file: %s', inputFile);
end
rawLines = {};
tline = fgetl(fid);
while ischar(tline)
    rawLines{end+1,1} = tline; %#ok<AGROW>
    tline = fgetl(fid);
end
fclose(fid);
nLines = numel(rawLines);

%% ---- FIND *Node BLOCK (exact match, line by line) ----
nodeStart = 0;
for k = 1:nLines
    if isKeywordMatch(rawLines{k}, '*Node')
        nodeStart = k;
        break;
    end
end
if nodeStart == 0
    error('Could not find a *Node keyword line.');
end

nodeEnd = nodeStart;
for k = (nodeStart+1):nLines
    if ~isempty(rawLines{k}) && rawLines{k}(1) == '*'
        break;
    end
    nodeEnd = k;
end

nodeBlockStr = strjoin(rawLines(nodeStart+1:nodeEnd), '\n');
nodeData = textscan(nodeBlockStr, '%f%f%f%f', 'Delimiter', ',', 'CollectOutput', true);
nodeData = nodeData{1};          % [id x y z]
nodeIDs    = nodeData(:,1);
nodeCoords = nodeData(:,2:4);

maxNodeID = max(nodeIDs);
nodeMap = zeros(maxNodeID, 1);
nodeMap(nodeIDs) = 1:numel(nodeIDs);

fprintf('Parsed %d nodes (lines %d-%d).\n', numel(nodeIDs), nodeStart, nodeEnd);

%% ---- FIND *Element BLOCK (exact match, line by line) ----
elemStart = 0;
for k = (nodeEnd+1):nLines
    if isKeywordMatch(rawLines{k}, '*Element')
        elemStart = k;
        break;
    end
end
if elemStart == 0
    error('Could not find an *Element keyword line.');
end

elemEnd = elemStart;
for k = (elemStart+1):nLines
    if ~isempty(rawLines{k}) && rawLines{k}(1) == '*'
        break;
    end
    elemEnd = k;
end

elemBlockStr = strjoin(rawLines(elemStart+1:elemEnd), '\n');
fmt = repmat('%f', 1, 11);   % id + 10 connectivity nodes
elemData = textscan(elemBlockStr, fmt, 'Delimiter', ',', 'CollectOutput', true);
elemData = elemData{1};       % [id n1 n2 ... n10]
elemIDs  = elemData(:,1);

fprintf('Parsed %d elements (lines %d-%d).\n', numel(elemIDs), elemStart, elemEnd);

%% ---- COMPUTE CENTROID & RADIUS (corner nodes = connectivity cols 2-5) ----
cornerNodes = elemData(:,2:5);              % [n1 n2 n3 n4] for every element
rows = nodeMap(cornerNodes);                % same size, row indices into nodeCoords
cx = mean(reshape(nodeCoords(rows,1), size(cornerNodes)), 2);
cy = mean(reshape(nodeCoords(rows,2), size(cornerNodes)), 2);
cz = mean(reshape(nodeCoords(rows,3), size(cornerNodes)), 2);

x_c = cx;
r_c = sqrt(cy.^2 + cz.^2);

%% ---- APPLY REMOVAL CRITERION ----
removeMask = (r_c < r0) & (x_c >= x1) & (x_c <= x2);
fprintf('Removing %d of %d elements (r < %.4g and x in [%.4g, %.4g]).\n', ...
    sum(removeMask), numel(elemIDs), r0, x1, x2);

keepMask     = ~removeMask;
keptElemData = elemData(keepMask, :);

%% ---- BUILD ABRBOT ELSET (surviving elements within [elsetLo, elsetHi]) ----
inRangeMask = (elemIDs >= elsetLo) & (elemIDs <= elsetHi);
abrbotIDs = sort(elemIDs(keepMask & inRangeMask));
fprintf('ABRBOT elset: %d elements remain in range [%d, %d].\n', ...
    numel(abrbotIDs), elsetLo, elsetHi);

%% ---- WRITE OUTPUT FILE ----
fidOut = fopen(outputFile, 'w');
if fidOut == -1
    error('Could not open output file: %s', outputFile);
end

% everything up to and including the node data, untouched
for k = 1:nodeEnd
    fprintf(fidOut, '%s\n', rawLines{k});
end

% lines between node block and element keyword line, untouched
for k = (nodeEnd+1):elemStart
    fprintf(fidOut, '%s\n', rawLines{k});
end

% regenerate element data lines from surviving elements
for k = 1:size(keptElemData,1)
    fprintf(fidOut, '%d, %d, %d, %d, %d, %d, %d, %d, %d, %d, %d\n', keptElemData(k,:));
end

% everything after the element block, untouched
for k = (elemEnd+1):nLines
    fprintf(fidOut, '%s\n', rawLines{k});
end

% ABRBOT elset, 8 IDs per line
fprintf(fidOut, '*ELSET, ELSET=ABRBOT\n');
nPerLine = 8;
for k = 1:nPerLine:numel(abrbotIDs)
    lineIDs = abrbotIDs(k:min(k+nPerLine-1, numel(abrbotIDs)));
    fprintf(fidOut, '%s\n', strjoin(cellstr(num2str(lineIDs(:), '%d')), ', '));
end

fclose(fidOut);
fprintf('Wrote filtered deck with ABRBOT elset to: %s\n', outputFile);

%% ---- LOCAL FUNCTIONS (must come after all script code in MATLAB) ----
function tf = isKeywordMatch(line, keyword)
    % Exact match on the first comma-delimited token of the line, so
    % e.g. '*Node output' does NOT match keyword '*Node'.
    tok = strtrim(strtok(line, ','));
    tf = strcmpi(tok, keyword);
end
