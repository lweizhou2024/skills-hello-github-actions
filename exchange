function X = normalizeRows(X)
    lengths = vecnorm(X,2,2);
    if any(lengths<eps)
        error("A zero-length normal vector was supplied or calculated.");
    end
    X = X./lengths;
end


function plotAlignment(TRcad,VscanAligned,Fscan,P,Q,N)
    figure("Name","Vane datum alignment");
    hold on;
    axis equal;
    grid on;
    view(3);

    trisurf(TRcad.ConnectivityList,TRcad.Points(:,1), ...
        TRcad.Points(:,2),TRcad.Points(:,3), ...
        "FaceAlpha",0.12,"EdgeColor","none");

    trisurf(Fscan,VscanAligned(:,1),VscanAligned(:,2), ...
        VscanAligned(:,3), ...
        "FaceAlpha",0.20,"EdgeColor","none");

    scatter3(P(:,1),P(:,2),P(:,3),55,"filled");
    scatter3(Q(:,1),Q(:,2),Q(:,3),35,"filled");

    scale = max(vecnorm(max(TRcad.Points)-min(TRcad.Points)))*0.03;
    quiver3(P(:,1),P(:,2),P(:,3), ...
        scale*N(:,1),scale*N(:,2),scale*N(:,3),0, ...
        "LineWidth",1.2);

    for i = 1:size(P,1)
        plot3([P(i,1),Q(i,1)],[P(i,2),Q(i,2)], ...
              [P(i,3),Q(i,3)],"k-");
        text(P(i,1),P(i,2),P(i,3),sprintf("  %d",i));
    end

    xlabel("X");
    ylabel("Y");
    zlabel("Z");
    legend("Nominal CAD","Aligned distorted mesh", ...
           "CAD targets","Measured/projected points","CAD normals");
    title("OB datum-target alignment");
end
