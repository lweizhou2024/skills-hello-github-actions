import ctypes
from ctypes import wintypes
import os
import time
from PIL import ImageGrab

folder = r"C:\screenshots"
os.makedirs(folder, exist_ok=True)

user32 = ctypes.windll.user32

MOD_NONE = 0
VK_F8 = 0x77

if not user32.RegisterHotKey(None, 1, MOD_NONE, VK_F8):
    raise RuntimeError("Failed to register hotkey")

print("Press F8 to take screenshot, ESC to exit")

i = 1

msg = wintypes.MSG()

while True:
    if user32.GetMessageA(ctypes.byref(msg), None, 0, 0) != 0:
        if msg.message == 0x0312:  # WM_HOTKEY
            img = ImageGrab.grab()
            filename = os.path.join(folder, f"a{i}.png")
            img.save(filename)
            print("Saved", filename)
            i += 1
        elif msg.message == 0x0100 and msg.wParam == 0x1B:  # ESC
            break
