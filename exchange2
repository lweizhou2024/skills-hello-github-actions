# IronPython, SpaceClaim API
curve = selection.Items[0]  # the curve you've selected
n_samples = 200             # increase if the curve has sharp local features
points = []

# Most curve objects expose a parametric range and an Evaluate(param) method
start, end = curve.Shape.Bounds  # or however your curve's parametric domain is exposed
for i in range(n_samples):
    t = start + (end - start) * i / (n_samples - 1)
    eval_result = curve.Shape.Evaluate(t)
    pt = eval_result.Point
    points.append((pt.X, pt.Y, pt.Z))

with open(r'C:\path\to\curve_points.csv', 'w') as f:
    for p in points:
        f.write('%.8f, %.8f, %.8f\n' % p)
